<article class="event{% if event.repertoire %} tall{% endif %}">
    <div class="date">{{ event.startDateFormatted }}{% if event.endDateFormatted %} &ndash; {{ event.endDateFormatted }}{% endif%}{% if event.time %}, {{ event.time }}{% endif %}</div>
    {% if headingLevel > 0 %}
    <h{{ headingLevel }} class="title">{{ event.title }}</h{{ headingLevel }}>
    {% else %}
    <h3 class="title">{{ event.title }}</h3>
    {% endif %}
    {% if event.repertoire %}<small>{{ event.repertoire | lineBreaksToBr | safe }}</small>{% endif %}
    {% if event.location %}<div class="location">{{ event.location }}</div>{% endif %}
    {% if event.role %}<div class="role">{{ event.role }}</div>{% endif %}
</article>